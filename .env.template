# Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=student_analytics
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_SSL_MODE=disable

# ============================================================================
# GOOGLE SHEETS CONFIGURATION
# ============================================================================
GOOGLE_CREDENTIALS_PATH=etl/Credentials.json
GOOGLE_SHEET_NAME=student_lifestyle_raw_data

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================
# Device: 'cuda' for GPU, 'cpu' for CPU
DEVICE=cuda

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# MODEL TRAINING CONFIGURATION
# ============================================================================
BATCH_SIZE=32
EPOCHS=100
LEARNING_RATE=0.001
WEIGHT_DECAY=0.00001
EARLY_STOPPING_PATIENCE=20

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=true

# ============================================================================
# MCP / AI CONFIGURATION
# ============================================================================
# Optional: for advanced MCP features
# MCP_MODEL=gpt-4
# MCP_API_KEY=your_openai_api_key
# MCP_TEMPERATURE=0.7
# MCP_MAX_TOKENS=2000

# ============================================================================
# OPTIONAL: API & DEPLOYMENT
# ============================================================================
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=4
# API_LOG_LEVEL=info

# ============================================================================
# DATA PATHS (usually no need to change)
# ============================================================================
DATA_DIR=data/
MODELS_DIR=outputs/models/
METRICS_DIR=outputs/metrics/
